@model TenderFormModalViewModel

<div class="modal fade" id="@Model.ModalId" tabindex="-1" aria-labelledby="@(Model.ModalId)Label" aria-describedby="@(Model.ModalId)Description" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Tender" asp-action="@Model.SubmitAction" asp-route-id="@Model.TenderId" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="@(Model.ModalId)Label">@Model.ModalTitle</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
                </div>

                <div class="modal-body">
                    <p id="@(Model.ModalId)Description" class="visually-hidden">
                        Vul de gegevens van het offertetraject in en kies daarna @Model.SubmitButtonText.ToLowerInvariant().
                    </p>
                    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert" aria-live="assertive">
                            @Model.ErrorMessage
                        </div>
                    }
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert" aria-live="assertive"></div>

                    <fieldset>
                        <legend class="visually-hidden">@Model.ModalTitle</legend>

                        <div class="mb-3">
                            <label asp-for="Form.Title" class="form-label"></label>
                            <input asp-for="Form.Title" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Form.Title" class="text-danger" aria-live="polite"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Form.Description" class="form-label"></label>
                            <textarea asp-for="Form.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Form.Description" class="text-danger" aria-live="polite"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Form.StartDate" class="form-label"></label>
                                <input asp-for="Form.StartDate" class="form-control" type="date" />
                                <span asp-validation-for="Form.StartDate" class="text-danger" aria-live="polite"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Form.EndDate" class="form-label"></label>
                                <input asp-for="Form.EndDate" class="form-control" type="date" />
                                <span asp-validation-for="Form.EndDate" class="text-danger" aria-live="polite"></span>
                            </div>
                        </div>

                        <div class="form-check">
                            <input asp-for="Form.IsPublic" class="form-check-input" />
                            <label asp-for="Form.IsPublic" class="form-check-label"></label>
                        </div>
                    </fieldset>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuleren</button>
                    <button type="submit" class="btn btn-dark">@Model.SubmitButtonText</button>
                </div>
            </form>
        </div>
    </div>
</div>
