@model TenderReviewPageViewModel

@{
    ViewData["Title"] = $"{Model.TenderTitle} - Beoordeling";
}

<nav aria-label="Terug navigatie" class="mb-3">
    <a asp-controller="Tender" asp-action="Details" asp-route-id="@Model.TenderId" class="btn btn-outline-secondary btn-sm">
        &larr; Terug naar offertetraject
    </a>
</nav>

<section class="submission-page">
    <article class="submission-panel">
        <header class="submission-panel__header">
            <div>
                <h1 class="submission-panel__title">@Model.TenderTitle</h1>
                <p class="submission-panel__description">@Model.TenderDescription</p>
            </div>
        </header>

        <section aria-labelledby="review-questions-heading">
            <h2 id="review-questions-heading" class="submission-panel__section-title">Offerte van @Model.SupplierName</h2>

            @if (TempData["TenderReviewSuccess"] is string successMessage)
            {
                <div class="alert alert-success" role="alert">
                    @successMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form asp-controller="TenderReview"
                  asp-action="Edit"
                  asp-route-tenderId="@Model.TenderId"
                  asp-route-submissionId="@Model.SubmissionId"
                  method="post"
                  class="review-form">
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(false, string.Empty, new { @class = "text-danger mb-3" })

                @foreach (var question in Model.Questions)
                {
                    <section class="review-question" aria-labelledby="review-question-@question.QuestionId">
                        <header class="review-question__header">
                            <h3 id="review-question-@question.QuestionId" class="review-question__title">
                                @question.Text
                            </h3>
                        </header>

                        <div class="review-question__answer">
                            @await Html.PartialAsync($"DisplayTemplates/{question.GetType().Name}", question)
                        </div>

                        @if (question.RatingInputIndex is int ratingIndex)
                        {
                            <fieldset class="review-rating">
                                <legend class="review-rating__legend">Beoordeling</legend>

                                <input type="hidden" asp-for="Form.Ratings[ratingIndex].QuestionId" />

                                <select class="form-select review-rating__select"
                                        asp-for="Form.Ratings[ratingIndex].Rating"
                                        aria-label="Beoordeling voor @question.Text">
                                    <option value="">Geen beoordeling</option>
                                    @foreach (var option in Model.RatingOptions)
                                    {
                                        <option value="@option.Value">@option.Label</option>
                                    }
                                </select>
                            </fieldset>
                        }
                    </section>
                }

                <button type="submit" class="btn btn-secondary submission-form__submit" id="saveReviewBtn">
                    Beoordeling opslaan
                </button>
            </form>
        </section>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('.review-form').addEventListener('submit', function (e) {
            const form = e.currentTarget;
            const submitBtn = document.getElementById('saveReviewBtn');

            if (submitBtn.disabled) {
                e.preventDefault();
                return false;
            }

            if (window.jQuery && !window.jQuery(form).valid()) {
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Wordt opgeslagen...';
        });
    </script>
}
