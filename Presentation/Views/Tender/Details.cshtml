@model Domain.Entities.Tender
@using Domain.Enums

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        &larr; Terug naar overzicht
    </a>
</div>

<h1 class="mb-4">@Model.Title</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge bg-@(Model.Status switch
                {
                    TenderStatus.Design => "secondary",
                    TenderStatus.Open => "success",
                    TenderStatus.Closed => "warning",
                    TenderStatus.Completed => "info",
                    _ => "secondary"
                })">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Omschrijving</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Startdatum</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd-MM-yyyy")</dd>

            <dt class="col-sm-3">Einddatum</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("dd-MM-yyyy")</dd>

            <dt class="col-sm-3">Openbaar</dt>
            <dd class="col-sm-9">@(Model.IsPublic ? "Ja" : "Nee")</dd>

            @if (Model.Organisation is not null)
            {
                <dt class="col-sm-3">Organisatie</dt>
                <dd class="col-sm-9">@Model.Organisation.Name</dd>
            }
        </dl>
    </div>
</div>
