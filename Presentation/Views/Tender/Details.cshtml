@model Domain.Entities.Tender
@using Domain.Enums

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        &larr; Terug naar overzicht
    </a>
</div>

<div class="row">
    <article class="col-lg-8">
        <h1 class="mb-4">@Model.Title</h1>

        <p>@Model.Description</p>

        @* Vragenlijst section will be added later *@
    </article>

    <aside class="col-lg-4">
        @if (Model.CanBeEdited())
        {
            <div class="d-grid mb-3">
                <button type="button" class="btn btn-dark">Offertetraject publiceren</button>
            </div>
        }

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Details</h5>
                <dl class="mb-0">
                    <dt>Status</dt>
                    <dd>@(Model.Status switch
                    {
                        TenderStatus.Design => "Ontwerp",
                        TenderStatus.Open => "Open",
                        TenderStatus.Closed => "Gesloten",
                        TenderStatus.Completed => "Afgerond",
                        _ => Model.Status.ToString()
                    })</dd>

                    <dt>Publiek</dt>
                    <dd>@(Model.IsPublic ? "Ja" : "Nee")</dd>

                    <dt>Begindatum</dt>
                    <dd>@Model.StartDate.ToString("dd/MM/yyyy")</dd>

                    <dt>Einddatum</dt>
                    <dd>@Model.EndDate.ToString("dd/MM/yyyy")</dd>
                </dl>
            </div>
        </div>

        @if (Model.CanBeEdited())
        {
            <div class="d-grid mb-3">
                <button type="button" class="btn btn-outline-secondary">Offertetraject wijzigen</button>
            </div>
        }
    </aside>
</div>
