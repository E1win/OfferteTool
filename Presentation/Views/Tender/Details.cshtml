@using Domain.Constants
@using Domain.Enums
@model TenderDetailsViewModel

@{
    ViewData["Title"] = Model.Tender.Title;
}

<nav aria-label="Terug navigatie" class="mb-3">
    <a asp-controller="Tender" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        &larr; Terug naar overzicht
    </a>
</nav>

<div class="row">
    <article class="col-lg-8">
        <header class="mb-4">
            <h1 class="mb-0">@Model.Tender.Title</h1>
        </header>

        <section aria-labelledby="description-heading">
            <h2 id="description-heading" class="h4">Beschrijving</h2>
            <p class="mb-0">@Model.Tender.Description</p>
        </section>

        @if (Model.ShowSupplierSubmissionSelection)
        {
            <section class="mt-5" aria-labelledby="submitted-tenders-heading">
                <h2 id="submitted-tenders-heading" class="h4">Ingediende offertes</h2>

                @if (Model.SupplierSubmissions.Count == 0)
                {
                    <p class="mb-0 text-body-secondary">Er zijn nog geen offertes ingediend.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var submission in Model.SupplierSubmissions)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action text-start"
                                    data-submission-id="@submission.SubmissionId">
                                @submission.Name
                            </button>
                        }
                    </div>
                }
            </section>
        }
        else
        {
            <partial name="_QuestionnaireEditorIsland" model="Model.QuestionnaireEditor" />
        }
    </article>

    <aside class="col-lg-4" aria-labelledby="tender-sidebar-heading">
        <h2 id="tender-sidebar-heading" class="visually-hidden">Tenderacties en details</h2>

        @if (!string.IsNullOrWhiteSpace(Model.ActionErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @Model.ActionErrorMessage
            </div>
        }

        @if (TempData["TenderSubmissionSuccess"] is string successMessage)
        {
            <div class="alert alert-success" role="alert">
                @successMessage
            </div>
        }

        @if (Model.CanManageTender && Model.Tender.CanBeEdited())
        {
            <div class="d-grid mb-3">
                <button type="button"
                        class="btn btn-dark"
                        aria-controls="@Model.OpenTenderModal!.ModalId"
                        aria-haspopup="dialog"
                        data-bs-toggle="modal"
                        data-bs-target="#@Model.OpenTenderModal!.ModalId">
                    Offertetraject openen
                </button>
            </div>

            <partial name="_ConfirmationModal" for="OpenTenderModal" />
        }
        
        @if (Model.CanManageTender && Model.Tender.Status == TenderStatus.Open)
        {
            <div class="d-grid mb-3">
                <button type="button"
                        class="btn btn-dark"
                        aria-controls="@Model.CloseTenderModal!.ModalId"
                        aria-haspopup="dialog"
                        data-bs-toggle="modal"
                        data-bs-target="#@Model.CloseTenderModal!.ModalId">
                    Offertetraject sluiten
                </button>
            </div>

            <partial name="_ConfirmationModal" for="CloseTenderModal" />
        }

        <div class="card mb-3">
            <div class="card-body">
                <h3 class="h5 card-title">Details</h3>
                <dl class="mb-0">
                    <dt>Opdrachtgever</dt>
                    <dd>@(Model.Tender.Organisation?.Name ?? "Onbekend")</dd>
                    <dt>Status</dt>
                    <dd>@(Model.Tender.Status switch
                    {
                        TenderStatus.Design => "Ontwerp",
                        TenderStatus.Open => "Open",
                        TenderStatus.Closed => "Gesloten",
                        TenderStatus.Completed => "Afgerond",
                        _ => Model.Tender.Status.ToString()
                    })</dd>

                    <dt>Publiek</dt>
                    <dd>@(Model.Tender.IsPublic ? "Ja" : "Nee")</dd>

                    <dt>Einddatum</dt>
                    <dd>@Model.Tender.EndDate.ToString("dd/MM/yyyy")</dd>
                </dl>

                @if (Model.CanManageTender)
                {
                    <h3 class="h5 card-title">Beoordelaars</h3>
                    @if (Model.AssignedReviewers.Count == 0)
                    {
                        <p class="mb-0 text-body-secondary">Er zijn nog geen beoordelaars toegewezen.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @for (var index = 0; index < Model.AssignedReviewers.Count; index++)
                            {
                                var reviewer = Model.AssignedReviewers[index];
                                var itemClass = index < Model.AssignedReviewers.Count - 1
                                ? "mb-3"
                                : string.Empty;

                                <li class="@itemClass">
                                    <span class="fw-semibold">@reviewer.Name</span>
                                </li>
                            }
                        </ul>
                    }

                    @if (Model.ReviewerAssignmentModal is not null)
                    {
                        <div class="d-grid mt-3">
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    aria-controls="@Model.ReviewerAssignmentModal.ModalId"
                                    aria-haspopup="dialog"
                                    data-bs-toggle="modal"
                                    data-bs-target="#@Model.ReviewerAssignmentModal.ModalId">
                                Beoordelaars wijzigen
                            </button>
                        </div>
                    }
                }

                @if (Model.CanManageTender && Model.Tender.Status == TenderStatus.Open)
                {
                    <h3 class="h5 card-title">Offertes ingediend door</h3>
                    @if (Model.SupplierSubmissions.Count == 0)
                    {
                        <p class="mb-0 text-body-secondary">Er zijn nog geen offertes ingediend.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @for (var index = 0; index < Model.SupplierSubmissions.Count; index++)
                            {
                                var submission = Model.SupplierSubmissions[index];
                                var itemClass = index < Model.SupplierSubmissions.Count - 1
                                ? "mb-3"
                                                                : string.Empty;

                                <li class="@itemClass">
                                    <span class="fw-semibold">@submission.Name</span>
                                </li>
                            }
                        </ul>
                    }
                }
            </div>
        </div>

        @if (User.IsInRole(Roles.Leverancier) && Model.Tender.Status == TenderStatus.Open)
        {
            <div class="d-grid mb-3">
                <a asp-controller="Tender"
                   asp-action="Submit"
                   asp-route-id="@Model.Tender.Id"
                   class="btn btn-dark">
                    Offerte indienen
                </a>
            </div>
        }

        @if (Model.EditTenderModal is not null)
        {
            <div class="d-grid mb-3">
                <button type="button"
                        class="btn btn-outline-secondary"
                        aria-controls="@Model.EditTenderModal.ModalId"
                        aria-haspopup="dialog"
                        data-bs-toggle="modal"
                        data-bs-target="#@Model.EditTenderModal.ModalId">
                    Offertetraject wijzigen
                </button>
            </div>

            <partial name="_TenderFormModal" for="EditTenderModal" />
        }

        @if (Model.ReviewerAssignmentModal is not null)
        {
            <partial name="_TenderReviewerAssignmentModal" for="ReviewerAssignmentModal" />
        }
    </aside>
</div>

@section Scripts {
    @if (!Model.ShowSupplierSubmissionSelection)
    {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/lib/vue/vue.global.prod.js"></script>
        <script src="~/js/questionnaire-editor.js" asp-append-version="true"></script>
    }

    @if (Model.EditTenderModal?.ShowOnLoad == true)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const modalElement = document.getElementById("@Model.EditTenderModal.ModalId");
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }

    @if (Model.ReviewerAssignmentModal?.ShowOnLoad == true)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const modalElement = document.getElementById("@Model.ReviewerAssignmentModal.ModalId");
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
}
