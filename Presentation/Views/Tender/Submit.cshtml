@using Domain.Entities.TenderQuestions
@using Domain.Enums
@model Presentation.Models.TenderSubmission.TenderSubmissionPageViewModel

@{
    ViewData["Title"] = $"{Model.Tender.Title} - Offerte indienen";
}

<nav aria-label="Terug navigatie" class="mb-3">
    <a asp-controller="Tender" asp-action="Details" asp-route-id="@Model.Tender.Id" class="btn btn-outline-secondary btn-sm">
        &larr; Terug naar offertetraject
    </a>
</nav>

<section class="submission-page">
    <article class="submission-panel">
        <header class="submission-panel__header">
            <h1 class="submission-panel__title">@Model.Tender.Title</h1>
            <p class="submission-panel__description">@Model.Tender.Description</p>
        </header>

        <section aria-labelledby="submission-questions-heading">
            <h2 id="submission-questions-heading" class="submission-panel__section-title">Vragenlijst</h2>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form asp-action="Submit" asp-route-id="@Model.Tender.Id" method="post" class="submission-form">
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(false, string.Empty, new { @class = "text-danger mb-3" })

                @for (var index = 0; index < Model.Questions.Count; index++)
                {
                    var question = Model.Questions[index];

                    <section class="submission-question">
                        <input asp-for="Form.Answers[index].QuestionId" type="hidden" />
                        <input asp-for="Form.Answers[index].Type" type="hidden" />

                        <h3 class="submission-question__title">@question.Text</h3>

                        @switch (question)
                        {
                            case TextQuestion textQuestion:
                                if (textQuestion.Rows > 1)
                                {
                                    <textarea asp-for="Form.Answers[index].TextValue"
                                                class="form-control submission-question__textarea"
                                                rows="@textQuestion.Rows"
                                                placeholder="Vul hier het antwoord in"></textarea>
                                }
                                else
                                {
                                    <input asp-for="Form.Answers[index].TextValue"
                                            class="form-control submission-question__input"
                                            placeholder="Vul hier het antwoord in" />
                                }

                                if (textQuestion.MaxLength.HasValue)
                                {
                                    <p class="form-text mb-0">Maximaal @textQuestion.MaxLength.Value tekens.</p>
                                }
                                break;

                            case NumberQuestion:
                                <input asp-for="Form.Answers[index].NumericValue"
                                        type="number"
                                        step="any"
                                        class="form-control submission-question__input"
                                        placeholder="Vul hier het antwoord in" />
                                break;

                            case ChoiceQuestion choiceQuestion:
                                <div class="submission-question__choices" role="group" aria-label="@question.Text">
                                    @foreach (var option in choiceQuestion.Options.OrderBy(option => option.Order))
                                    {
                                        var inputId = $"question-{question.Id}-option-{option.Id}";
                                        var selectedOptionIds = Model.Form.Answers[index].SelectedOptionIds;

                                        <label class="submission-choice" for="@inputId">
                                            <input id="@inputId"
                                                    class="submission-choice__input"
                                                    type="@(choiceQuestion.AllowMultipleSelection ? "checkbox" : "radio")"
                                                    name="Form.Answers[@index].SelectedOptionIds"
                                                    value="@option.Id"
                                                    checked="@selectedOptionIds.Contains(option.Id)" />
                                            <span class="submission-choice__label">@option.Text</span>
                                        </label>
                                    }
                                </div>
                                break;
                        }
                    </section>
                }

                <button type="submit" class="btn btn-secondary submission-form__submit">
                    Offerte indienen
                </button>
            </form>
        </section>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
