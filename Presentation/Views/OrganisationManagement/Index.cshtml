@using Domain.Enums
@model OrganisationManagementIndexViewModel

@{
    ViewData["Title"] = "Organisaties";
}

<header class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Organisaties</h1>

    <button type="button"
            class="btn btn-dark"
            aria-controls="@Model.CreateOrganisationModal.ModalId"
            aria-haspopup="dialog"
            data-bs-toggle="modal"
            data-bs-target="#@Model.CreateOrganisationModal.ModalId">
        Nieuwe organisatie
    </button>
</header>

@if (TempData["OrganisationManagementSuccess"] is string successMessage)
{
    <div class="alert alert-success" role="status">
        @successMessage
    </div>
}

<form method="get" asp-controller="OrganisationManagement" asp-action="Index" class="mb-4">
    <label for="search" class="form-label">Zoeken</label>
    <div class="input-group mb-2">
        <input id="search"
               name="search"
               value="@Model.Search"
               class="form-control"
               placeholder="Naam, KvK-nummer of type" />
        <button type="submit" class="btn btn-dark">Zoeken</button>

        @if (!string.IsNullOrWhiteSpace(Model.Search) || Model.IncludeInactive)
        {
            <a asp-controller="OrganisationManagement"
               asp-action="Index"
               class="btn btn-outline-secondary">
                Wissen
            </a>
        }
    </div>

    <div class="form-check">
        <input id="includeInactive"
               name="includeInactive"
               type="checkbox"
               value="true"
               class="form-check-input"
               @(Model.IncludeInactive ? "checked" : string.Empty) />
        <label for="includeInactive" class="form-check-label">Inactieve organisaties tonen</label>
    </div>
</form>

@if (Model.Organisations.Count == 0)
{
    <section aria-labelledby="empty-organisations-heading">
        <h2 id="empty-organisations-heading" class="visually-hidden">Geen organisaties beschikbaar</h2>
        <p class="text-muted mb-0">
            @(string.IsNullOrWhiteSpace(Model.Search)
                ? "Er zijn geen organisaties beschikbaar."
                : "Er zijn geen organisaties gevonden die aan uw zoekopdracht voldoen.")
        </p>
    </section>
}
else
{
    <section aria-labelledby="organisations-table-heading">
        <h2 id="organisations-table-heading" class="visually-hidden">Organisatieoverzicht</h2>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <caption class="visually-hidden">Overzicht van organisaties</caption>
                <thead>
                    <tr>
                        <th scope="col">Naam</th>
                        <th scope="col">KvK-nummer</th>
                        <th scope="col">Type</th>
                        <th scope="col">Actief</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var organisation in Model.Organisations)
                    {
                        <tr class="organisation-management-row"
                            role="button"
                            tabindex="0"
                            title="Organisatie wijzigen"
                            aria-label="Organisatie @organisation.Name wijzigen"
                            data-organisation-id="@organisation.Id"
                            data-organisation-name="@organisation.Name"
                            data-organisation-kvk-number="@organisation.KvkNumber"
                            data-organisation-type="@organisation.OrganisationType"
                            data-organisation-is-active="@organisation.IsActive.ToString().ToLowerInvariant()">
                            <th scope="row" class="fw-normal">@organisation.Name</th>
                            <td>@organisation.KvkNumber</td>
                            <td>@FormatOrganisationType(organisation.OrganisationType)</td>
                            <td>
                                <span role="img" aria-label="@(organisation.IsActive ? "Actief" : "Inactief")">
                                    @if (organisation.IsActive)
                                    {
                                        <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M22 5L10.0555 16.6321C9.81351 16.8677 9.48537 17 9.14323 17C8.80108 17 8.47294 16.8677 8.23097 16.6321L2 10.5641" stroke="#84CB7C" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M20 20L4 4M20 4L4 20" stroke="#E12E2E" stroke-width="3" stroke-linecap="round" />
                                        </svg>
                                    }
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<partial name="_OrganisationFormModal" for="CreateOrganisationModal" />
<partial name="_OrganisationFormModal" for="EditOrganisationModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const editModalElement = document.getElementById("@Model.EditOrganisationModal.ModalId");
            const editModal = editModalElement ? bootstrap.Modal.getOrCreateInstance(editModalElement) : null;

            const setValue = (name, value) => {
                const field = editModalElement?.querySelector(`[name="${name}"]`);
                if (field) {
                    field.value = value ?? "";
                }
            };

            const setChecked = (name, value) => {
                const field = editModalElement?.querySelector(`[name="${name}"]`);
                if (field) {
                    field.checked = value === "true";
                }
            };

            const openEditModal = (row) => {
                if (!editModalElement || !editModal) {
                    return;
                }

                setValue("EditOrganisationModal.Form.Id", row.dataset.organisationId);
                setValue("EditOrganisationModal.Form.Name", row.dataset.organisationName);
                setValue("EditOrganisationModal.Form.KvkNumber", row.dataset.organisationKvkNumber);
                setValue("EditOrganisationModal.Form.OrganisationType", row.dataset.organisationType);
                setChecked("EditOrganisationModal.Form.IsActive", row.dataset.organisationIsActive);

                editModal.show();
            };

            document.querySelectorAll(".organisation-management-row").forEach((row) => {
                row.addEventListener("click", () => openEditModal(row));
                row.addEventListener("keydown", (event) => {
                    if (event.key === "Enter" || event.key === " ") {
                        event.preventDefault();
                        openEditModal(row);
                    }
                });
            });
        });
    </script>

    @if (Model.CreateOrganisationModal.ShowOnLoad || Model.EditOrganisationModal.ShowOnLoad)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const modalId = "@(Model.EditOrganisationModal.ShowOnLoad ? Model.EditOrganisationModal.ModalId : Model.CreateOrganisationModal.ModalId)";
                const modalElement = document.getElementById(modalId);
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
}

@functions {
    private static string FormatOrganisationType(OrganisationType organisationType) =>
        organisationType switch
        {
            OrganisationType.Client => "Opdrachtgever",
            OrganisationType.Supplier => "Leverancier",
            _ => organisationType.ToString()
        };
}
